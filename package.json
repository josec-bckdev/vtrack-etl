{
	"name": "vtrack-etl",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"scripts": {
		"build": "rimraf dist && tsc",
		"start": "node dist/api/server.js",
		"dev": "nodemon --watch src --ext ts --exec ts-node src/api/server.ts",
		"test": "jest --runInBand --forceExit",
		"test:coverage": "jest --runInBand --forceExit --coverage",
		"prisma:migrate": "prisma migrate dev",
		"prisma:seed": "ts-node src/infrastructure/db/prisma/seed.ts",
		"prisma:studio": "prisma studio",
		"prepare": "husky",
		"commit": "cz"
	},
	"config": {
		"commitizen": {
			"path": "cz-conventional-changelog"
		}
	},
	"jest": {
		"preset": "ts-jest",
		"testEnvironment": "node",
		"roots": [
			"<rootDir>/tests"
		],
		"testMatch": [
			"**/*.test.ts"
		],
		"collectCoverageFrom": [
			"src/**/*.ts",
			"!src/infrastructure/db/prisma/seed.ts",
			"!src/api/server.ts"
		],
		"coverageThreshold": {
			"global": {
				"lines": 95,
				"functions": 95,
				"branches": 95
			}
		}
	},
	"author": "",
	"license": "ISC",
	"dependencies": {
		"@prisma/adapter-pg": "^7.5.0",
		"@prisma/client": "^7.5.0",
		"axios": "^1.13.6",
		"express": "^5.2.1",
		"js-yaml": "^4.1.1",
		"node-cron": "^4.2.1",
		"pg": "^8.20.0",
		"prisma": "^7.5.0",
		"winston": "^3.19.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@types/axios": "^0.9.36",
		"@types/express": "^5.0.6",
		"@types/jest": "^30.0.0",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.5.0",
		"@types/node-cron": "^3.0.11",
		"@types/supertest": "^7.2.0",
		"commitizen": "^4.3.1",
		"cz-conventional-changelog": "^3.3.0",
		"dotenv": "^17.3.1",
		"husky": "^9.1.7",
		"jest": "^30.3.0",
		"nodemon": "^3.1.14",
		"rimraf": "^6.1.3",
		"supertest": "^7.2.2",
		"ts-jest": "^29.4.6",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3"
	}
}
